###> Appart Hôtel Tricastin — Variables d'environnement ###

# ---- Application ----
APP_URL=http://localhost:8000
CONTACT_EMAIL=contact@appart-hotel-tricastin.fr

# ---- Base de données ----
DATABASE_URL="mysql://root:@127.0.0.1:3306/appart_hotel_tricastin?serverVersion=8.0"

# ---- Mailer (Mailtrap en dev / SMTP en prod) ----
MAILER_DSN=smtp://user:pass@sandbox.smtp.mailtrap.io:2525

# ---- Cloudinary (upload d'images) ----
# Format : cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://123456789:abcdefghijk@your-cloud-name

# ---- Stripe (paiements en ligne) ----
# Clés de test (préfixe sk_test_ et pk_test_)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

###< Appart Hôtel Tricastin ###
