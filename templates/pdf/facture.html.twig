<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.5; }

        .container { padding: 30px 40px; }

        /* ── En-tête ──────────────────────────────── */
        .header { display: table; width: 100%; margin-bottom: 30px; border-bottom: 3px solid #B8860B; padding-bottom: 20px; }
        .header-left { display: table-cell; width: 50%; vertical-align: top; }
        .header-right { display: table-cell; width: 50%; vertical-align: top; text-align: right; }
        .company-name { font-size: 22px; font-weight: bold; color: #2C3E50; margin-bottom: 2px; }
        .company-sub { font-size: 10px; color: #B8860B; letter-spacing: 2px; text-transform: uppercase; }
        .facture-title { font-size: 28px; font-weight: bold; color: #B8860B; }
        .facture-numero { font-size: 13px; color: #666; margin-top: 4px; }

        /* ── Infos client / facturation ────────────── */
        .info-row { display: table; width: 100%; margin-bottom: 25px; }
        .info-col { display: table-cell; width: 50%; vertical-align: top; }
        .info-box { background: #f8f6f2; border-left: 3px solid #B8860B; padding: 12px 15px; margin-right: 15px; }
        .info-box-right { background: #f0f4f8; border-left: 3px solid #2C3E50; padding: 12px 15px; }
        .info-title { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #999; margin-bottom: 6px; font-weight: bold; }
        .info-value { font-size: 12px; color: #333; }
        .info-value strong { color: #2C3E50; }

        /* ── Tableau détail ────────────────────────── */
        table.detail { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
        table.detail th { background: #2C3E50; color: #fff; padding: 10px 12px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; text-align: left; }
        table.detail td { padding: 10px 12px; border-bottom: 1px solid #eee; font-size: 11px; }
        table.detail tr:nth-child(even) td { background: #fafafa; }
        table.detail .text-right { text-align: right; }

        /* ── Totaux ────────────────────────────────── */
        .totaux { display: table; width: 100%; margin-bottom: 25px; }
        .totaux-spacer { display: table-cell; width: 55%; }
        .totaux-box { display: table-cell; width: 45%; }
        .totaux-table { width: 100%; border-collapse: collapse; }
        .totaux-table td { padding: 8px 12px; font-size: 12px; }
        .totaux-table .label { text-align: left; color: #666; }
        .totaux-table .value { text-align: right; font-weight: bold; }
        .totaux-table .total-row td { background: #B8860B; color: #fff; font-size: 14px; font-weight: bold; }
        .totaux-table .paye-row td { background: #27ae60; color: #fff; }
        .totaux-table .solde-row td { background: #e74c3c; color: #fff; }
        .totaux-table .solde-ok td { background: #27ae60; color: #fff; }

        /* ── Paiements ─────────────────────────────── */
        table.paiements { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
        table.paiements th { background: #f0f4f8; color: #2C3E50; padding: 8px 10px; font-size: 10px; text-transform: uppercase; text-align: left; border-bottom: 2px solid #2C3E50; }
        table.paiements td { padding: 8px 10px; border-bottom: 1px solid #eee; font-size: 11px; }

        /* ── Pied de page ──────────────────────────── */
        .footer { border-top: 2px solid #eee; padding-top: 15px; margin-top: 30px; text-align: center; font-size: 9px; color: #999; }
        .footer strong { color: #B8860B; }

        /* ── Badges statut ─────────────────────────── */
        .badge { display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 10px; font-weight: bold; color: #fff; }
        .badge-confirmee { background: #27ae60; }
        .badge-en_attente { background: #f39c12; }
        .badge-annulee { background: #e74c3c; }
        .badge-terminee { background: #95a5a6; }
    </style>
</head>
<body>
<div class="container">

    <!-- ════════════════════════════════════════════ -->
    <!-- EN-TÊTE                                      -->
    <!-- ════════════════════════════════════════════ -->
    <div class="header">
        <div class="header-left">
            <div class="company-name">Appart H&ocirc;tel Tricastin</div>
            <div class="company-sub">Location d'appartements meubl&eacute;s</div>
            <div style="margin-top:8px; font-size:10px; color:#666;">
                Dr&ocirc;me Proven&ccedil;ale<br>
                contact@appart-hotel-tricastin.fr
            </div>
        </div>
        <div class="header-right">
            <div class="facture-title">FACTURE</div>
            <div class="facture-numero">N&deg; {{ numeroFacture }}</div>
            <div style="font-size:10px; color:#999; margin-top:8px;">
                Date d'&eacute;mission : {{ dateEmission|date('d/m/Y') }}
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════ -->
    <!-- INFOS CLIENT + RÉSERVATION                   -->
    <!-- ════════════════════════════════════════════ -->
    <div class="info-row">
        <div class="info-col">
            <div class="info-box">
                <div class="info-title">Client</div>
                <div class="info-value">
                    <strong>{{ reservation.prenom }} {{ reservation.nom }}</strong><br>
                    {{ reservation.email }}<br>
                    {{ reservation.telephone }}
                </div>
            </div>
        </div>
        <div class="info-col">
            <div class="info-box-right">
                <div class="info-title">R&eacute;servation</div>
                <div class="info-value">
                    <strong>{{ reservation.appartement.nom }}</strong><br>
                    {{ reservation.appartement.localisation.ville }}<br>
                    Du {{ reservation.dateArrivee|date('d/m/Y') }} au {{ reservation.dateDepart|date('d/m/Y') }}<br>
                    {{ nbNuits }} nuit{{ nbNuits > 1 ? 's' : '' }} &mdash; {{ reservation.nombrePersonnes }} personne{{ reservation.nombrePersonnes > 1 ? 's' : '' }}<br>
                    <span class="badge badge-{{ reservation.statut }}">{{ reservation.statutLabel }}</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════════ -->
    <!-- DÉTAIL DE LA PRESTATION                      -->
    <!-- ════════════════════════════════════════════ -->
    <table class="detail">
        <thead>
            <tr>
                <th>D&eacute;signation</th>
                <th>Appartement</th>
                <th class="text-right">Prix / nuit</th>
                <th class="text-right">Nb nuits</th>
                <th class="text-right">Total HT</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>H&eacute;bergement meubl&eacute;</td>
                <td>{{ reservation.appartement.nom }} ({{ reservation.appartement.type }})</td>
                <td class="text-right">{{ prixNuit|number_format(2, ',', ' ') }} &euro;</td>
                <td class="text-right">{{ nbNuits }}</td>
                <td class="text-right"><strong>{{ montantTotal|number_format(2, ',', ' ') }} &euro;</strong></td>
            </tr>
        </tbody>
    </table>

    <!-- ════════════════════════════════════════════ -->
    <!-- TOTAUX                                       -->
    <!-- ════════════════════════════════════════════ -->
    <div class="totaux">
        <div class="totaux-spacer"></div>
        <div class="totaux-box">
            <table class="totaux-table">
                <tr>
                    <td class="label">Total HT</td>
                    <td class="value">{{ montantTotal|number_format(2, ',', ' ') }} &euro;</td>
                </tr>
                <tr>
                    <td class="label">TVA (non applicable*)</td>
                    <td class="value">0,00 &euro;</td>
                </tr>
                <tr class="total-row">
                    <td>TOTAL TTC</td>
                    <td style="text-align:right;">{{ montantTotal|number_format(2, ',', ' ') }} &euro;</td>
                </tr>
                <tr class="paye-row">
                    <td>D&eacute;j&agrave; pay&eacute;</td>
                    <td style="text-align:right;">{{ totalPaye|number_format(2, ',', ' ') }} &euro;</td>
                </tr>
                <tr class="{{ soldeRestant <= 0 ? 'solde-ok' : 'solde-row' }}">
                    <td>{{ soldeRestant <= 0 ? 'Sold&eacute;' : 'Reste &agrave; payer' }}</td>
                    <td style="text-align:right;">{{ soldeRestant|number_format(2, ',', ' ') }} &euro;</td>
                </tr>
            </table>
        </div>
    </div>

    <!-- ════════════════════════════════════════════ -->
    <!-- HISTORIQUE DES PAIEMENTS                     -->
    <!-- ════════════════════════════════════════════ -->
    {% if paiements|length > 0 %}
    <h3 style="font-size:12px; color:#2C3E50; margin-bottom:10px; text-transform:uppercase; letter-spacing:1px;">
        Historique des paiements
    </h3>
    <table class="paiements">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Statut</th>
                <th style="text-align:right;">Montant</th>
            </tr>
        </thead>
        <tbody>
            {% for p in paiements %}
            <tr>
                <td>{{ p.date|date('d/m/Y') }}</td>
                <td>{{ p.type }}</td>
                <td>{{ p.statut }}</td>
                <td style="text-align:right;">{{ p.montant|number_format(2, ',', ' ') }} &euro;</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <!-- ════════════════════════════════════════════ -->
    <!-- PIED DE PAGE                                 -->
    <!-- ════════════════════════════════════════════ -->
    <div class="footer">
        <strong>Appart H&ocirc;tel Tricastin</strong> &mdash; Location d'appartements meubl&eacute;s en Dr&ocirc;me Proven&ccedil;ale<br>
        * TVA non applicable, art. 293 B du CGI (r&eacute;gime micro-entreprise ou franchise en base)<br>
        Facture g&eacute;n&eacute;r&eacute;e automatiquement le {{ dateEmission|date('d/m/Y &agrave; H:i') }}
    </div>

</div>
</body>
</html>
