{% extends 'base.html.twig' %}

{% block title %}404 — {{ 'site.title'|trans }}{% endblock %}

{% block body %}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        <h1>404</h1>
        <p class="lead">Page non trouvée</p>
    </div>
</section>

<section class="py-5">
    <div class="container text-center">
        <div class="py-5">
            <i class="bi bi-house-exclamation text-primary" style="font-size: 5rem;"></i>
            <h2 class="mt-4 mb-3">Oups ! Cette page n'existe pas</h2>
            <p class="text-muted mb-4">
                La page que vous cherchez a peut-être été déplacée ou n'existe plus.
            </p>
            <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg me-2">
                <i class="bi bi-house-door"></i> {{ 'nav.home'|trans }}
            </a>
            <a href="{{ path('app_appartements') }}" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-search"></i> {{ 'nav.apartments'|trans }}
            </a>
        </div>
    </div>
</section>
{% endblock %}
