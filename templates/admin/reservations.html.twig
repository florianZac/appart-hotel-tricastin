{% extends 'admin/base.html.twig' %}

{% block title %}Réservations{% endblock %}

{% block admin_body %}
<div class="admin-topbar">
    <h1><i class="bi bi-calendar-check"></i> Réservations</h1>
</div>

<div class="table-card">
    <div class="card-header">
        <i class="bi bi-list-ul"></i> Toutes les réservations ({{ reservations|length }})
    </div>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Client</th>
                    <th>Contact</th>
                    <th>Appartement</th>
                    <th>Arrivée</th>
                    <th>Départ</th>
                    <th>Nuits</th>
                    <th>Pers.</th>
                    <th>Statut</th>
                    <th>Message</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                <tr>
                    <td><strong>{{ reservation.id }}</strong></td>
                    <td>
                        <strong>{{ reservation.prenom }} {{ reservation.nom }}</strong>
                    </td>
                    <td>
                        <small>
                            <i class="bi bi-envelope"></i> {{ reservation.email }}<br>
                            <i class="bi bi-telephone"></i> {{ reservation.telephone }}
                        </small>
                    </td>
                    <td>{{ reservation.appartement ? reservation.appartement.nom : '—' }}</td>
                    <td>{{ reservation.dateArrivee|date('d/m/Y') }}</td>
                    <td>{{ reservation.dateDepart|date('d/m/Y') }}</td>
                    <td><strong>{{ reservation.nombreNuits }}</strong></td>
                    <td>{{ reservation.nombrePersonnes }}</td>
                    <td>
                        {% if reservation.statut == 'en_attente' %}
                            <span class="badge-statut bg-warning text-dark">En attente</span>
                        {% elseif reservation.statut == 'confirmee' %}
                            <span class="badge-statut bg-success text-white">Confirmée</span>
                        {% elseif reservation.statut == 'annulee' %}
                            <span class="badge-statut bg-danger text-white">Annulée</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if reservation.message %}
                            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip"
                                    title="{{ reservation.message }}">
                                <i class="bi bi-chat-text"></i>
                            </button>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            {% if reservation.statut != 'confirmee' %}
                            <form method="POST"
                                  action="{{ path('admin_reservation_statut', {id: reservation.id, statut: 'confirmee'}) }}"
                                  style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('statut_' ~ reservation.id) }}">
                                <button type="submit" class="btn btn-sm btn-success" title="Confirmer">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                            {% endif %}

                            {% if reservation.statut != 'annulee' %}
                            <form method="POST"
                                  action="{{ path('admin_reservation_statut', {id: reservation.id, statut: 'annulee'}) }}"
                                  style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('statut_' ~ reservation.id) }}">
                                <button type="submit" class="btn btn-sm btn-danger" title="Annuler">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="11" class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i><br>
                        Aucune réservation pour le moment
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const tooltips = document.querySelectorAll('[data-bs-toggle="tooltip"]');
    tooltips.forEach(t => new bootstrap.Tooltip(t));
});
</script>
{% endblock %}
