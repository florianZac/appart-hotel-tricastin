<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — Appart Hôtel Tricastin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --admin-primary: #b8860b;
            --admin-dark: #1a1a2e;
            --admin-sidebar: #2c3e50;
        }
        body { font-family: 'Montserrat', sans-serif; background: #f4f6f9; }
        .admin-sidebar {
            position: fixed; top: 0; left: 0; width: 260px; height: 100vh;
            background: var(--admin-sidebar); color: #fff; padding: 0;
            overflow-y: auto; z-index: 1000;
        }
        .admin-sidebar .brand {
            padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.1);
            font-weight: 700; font-size: 1.1rem;
        }
        .admin-sidebar .brand small { display: block; font-size: 0.7rem; color: var(--admin-primary); text-transform: uppercase; letter-spacing: 2px; }
        .admin-sidebar .nav-link {
            color: rgba(255,255,255,0.7); padding: 12px 24px;
            font-size: 0.9rem; display: flex; align-items: center; gap: 10px;
            transition: all 0.2s;
        }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active { color: #fff; background: rgba(184,134,11,0.2); border-left: 3px solid var(--admin-primary); }
        .admin-sidebar .nav-link i { font-size: 1.1rem; width: 22px; text-align: center; }
        .admin-sidebar .nav-divider { border-top: 1px solid rgba(255,255,255,0.08); margin: 12px 0; }
        .admin-content { margin-left: 260px; padding: 24px 32px; min-height: 100vh; }
        .admin-topbar {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 28px; padding-bottom: 16px; border-bottom: 1px solid #e0e0e0;
        }
        .admin-topbar h1 { font-size: 1.6rem; font-weight: 700; color: var(--admin-dark); margin: 0; }
        .stat-card {
            background: #fff; border-radius: 12px; padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.3s;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
        .stat-card .stat-icon {
            width: 50px; height: 50px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
        }
        .stat-card .stat-value { font-size: 2rem; font-weight: 700; color: var(--admin-dark); }
        .stat-card .stat-label { font-size: 0.85rem; color: #888; }
        .table-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden; }
        .table-card .card-header { background: #fff; border-bottom: 2px solid #f0f0f0; padding: 16px 24px; font-weight: 600; }
        .table-card table { margin: 0; }
        .table-card th { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; color: #888; font-weight: 600; border: none; padding: 12px 16px; }
        .table-card td { padding: 14px 16px; vertical-align: middle; border-color: #f5f5f5; font-size: 0.9rem; }
        .badge-statut { padding: 5px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 600; }

        @media (max-width: 991.98px) {
            .admin-sidebar { width: 100%; height: auto; position: static; }
            .admin-content { margin-left: 0; }
        }
    </style>
</head>
<body>
    {# Sidebar #}
    <aside class="admin-sidebar">
        <div class="brand">
            Appart Hôtel
            <small>Back-office</small>
        </div>
        <nav class="mt-2">
            <a class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}"
               href="{{ path('admin_dashboard') }}">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="nav-link {% if app.request.attributes.get('_route') == 'admin_reservations' %}active{% endif %}"
               href="{{ path('admin_reservations') }}">
                <i class="bi bi-calendar-check"></i> Réservations
            </a>
            <div class="nav-divider"></div>
            <a class="nav-link" href="{{ path('app_home') }}" target="_blank">
                <i class="bi bi-box-arrow-up-right"></i> Voir le site
            </a>
        </nav>
    </aside>

    {# Content #}
    <main class="admin-content">
        {# Flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block admin_body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
