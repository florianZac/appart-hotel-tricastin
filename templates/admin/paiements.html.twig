{% extends 'base.html.twig' %}

{% block title %}Gestion des paiements — Admin{% endblock %}

{% block stylesheets %}
<style>
  .admin-header { background: #1a2744; padding: 60px 0 30px; margin-top: 80px; }
  .admin-header h1 { font-family: 'Cormorant Garamond', serif; color: #c8a962; }
  .stat-mini { background: #fff; border-radius: 8px; padding: 15px; box-shadow: 0 2px 6px rgba(0,0,0,.06); text-align: center; }
  .stat-mini h4 { margin: 0; font-size: 1.4rem; color: #1a2744; }
  .stat-mini p { margin: 0; font-size: .8rem; color: #666; }
  .en-retard { background-color: #fff5f5 !important; }
</style>
{% endblock %}

{% block body %}
<section class="admin-header">
  <div class="container">
    <h1><i class="bi bi-credit-card"></i> Gestion des paiements</h1>
  </div>
</section>

<section class="py-4">
  <div class="container">
    {# Statistiques rapides #}
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="stat-mini">
          <h4>{{ revenusMois is defined ? revenusMois|number_format(0, ',', ' ') : '0' }}€</h4>
          <p>Revenus ce mois</p>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-mini" {% if paiementsRetard|length > 0 %}style="border: 2px solid #e74c3c;"{% endif %}>
          <h4>{{ paiementsRetard|length }}</h4>
          <p>Paiements en retard</p>
        </div>
      </div>
      {% for type, total in revenus %}
      <div class="col-md-3">
        <div class="stat-mini">
          <h4>{{ total|number_format(0, ',', ' ') }}€</h4>
          <p>{{ type }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

    {# Paiements en retard #}
    {% if paiementsRetard|length > 0 %}
    <div class="alert alert-danger">
      <strong><i class="bi bi-exclamation-triangle"></i> {{ paiementsRetard|length }} paiement(s) en retard</strong>
    </div>
    {% endif %}

    {# Tableau des paiements #}
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Client</th>
            <th>Type</th>
            <th>Description</th>
            <th>Échéance</th>
            <th>Montant</th>
            <th>Statut</th>
            <th>Payé le</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for p in payments %}
          <tr class="{% if p.enRetard %}en-retard{% endif %}">
            <td>{{ p.id }}</td>
            <td>
              <strong>{{ p.user.fullName }}</strong><br>
              <small class="text-muted">{{ p.user.email }}</small>
            </td>
            <td>{{ p.typeLabel }}</td>
            <td>{{ p.description|default('—')|u.truncate(40) }}</td>
            <td>
              {% if p.dateEcheance %}
                {{ p.dateEcheance|date('d/m/Y') }}
                {% if p.enRetard %}<br><span class="badge bg-danger">En retard</span>{% endif %}
              {% else %}—{% endif %}
            </td>
            <td><strong>{{ p.montant }}€</strong></td>
            <td><span class="badge bg-{{ p.statutBadgeClass }}">{{ p.statutLabel }}</span></td>
            <td>{{ p.paidAt ? p.paidAt|date('d/m/Y') : '—' }}</td>
            <td>
              {% if p.statut == 'reussi' and p.stripePaymentIntentId %}
                <button class="btn btn-sm btn-outline-danger"
                        onclick="if(confirm('Rembourser ce paiement de {{ p.montant }}€ ?')) refundPayment({{ p.id }})">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% block javascripts %}
<script>
async function refundPayment(id) {
  try {
    const response = await fetch(`/admin/paiement/${id}/rembourser`, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const data = await response.json();
    if (response.ok) {
      alert('Remboursement effectué !');
      location.reload();
    } else {
      alert('Erreur : ' + (data.error || 'Erreur inconnue'));
    }
  } catch (e) {
    alert('Erreur réseau');
  }
}
</script>
{% endblock %}
{% endblock %}
