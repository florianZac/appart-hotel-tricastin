{% extends 'admin/base.html.twig' %}

{% block title %}Comptabilité — Export{% endblock %}

{% block admin_body %}
<div class="container-fluid py-4">

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# ════════════════════════════════════════════════════════ #}
    {# 1. EXPORT EXCEL MULTI-ONGLETS (nouveau)                 #}
    {# ════════════════════════════════════════════════════════ #}
    <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #B8860B !important;">
        <div class="card-header text-white d-flex align-items-center gap-2"
             style="background:#1A2744;">
            <i class="bi bi-file-earmark-excel fs-5 text-success"></i>
            <h5 class="mb-0">Export Excel — Multi-onglets par localisation</h5>
            <span class="badge bg-success ms-2">Nouveau</span>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Génère un fichier <strong>.xlsx</strong> avec
                <strong>1 onglet par localisation</strong> + <strong>1 onglet Récapitulatif global</strong>.
                Chaque onglet contient : réservations mois par mois, taux d'occupation, frais et bilan financier.
            </p>

            <div class="row g-3 mb-3 small text-muted">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge" style="background:#C8A962; color:#1A2744; width:24px; height:24px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px;">1</span>
                        <strong>Onglet Pont-Saint-Esprit</strong> — réservations + frais + bilan
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge" style="background:#C8A962; color:#1A2744; width:24px; height:24px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px;">2</span>
                        <strong>Onglet Tulette</strong> — réservations + frais + bilan
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge" style="background:#2C3E50; color:#fff; width:24px; height:24px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px;">∑</span>
                        <strong>Onglet Récapitulatif</strong> — comparatif consolidé
                    </div>
                </div>
            </div>

            {{ form_start(formExport, {
                'action': path('admin_comptabilite_export_xlsx'),
                'attr': {'class': ''}
            }) }}

                <div class="d-flex flex-wrap gap-3 align-items-end">
                    <div style="min-width: 160px;">
                        {{ form_row(formExport.annee) }}
                    </div>
                    <div style="min-width: 260px;">
                        {{ form_row(formExport.localisation) }}
                    </div>
                    <div>
                        <button type="submit" class="btn btn-success btn-lg d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-excel"></i>
                            Télécharger le fichier Excel
                        </button>
                    </div>
                </div>

            {{ form_end(formExport) }}
        </div>
    </div>

    {# ════════════════════════════════════════════════════════ #}
    {# 2. EXPORT CSV (historique)                              #}
    {# ════════════════════════════════════════════════════════ #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-secondary text-white d-flex align-items-center gap-2"
             data-bs-toggle="collapse" data-bs-target="#csvSection"
             style="cursor:pointer;">
            <i class="bi bi-filetype-csv fs-5"></i>
            <h5 class="mb-0">Export CSV (format legacy)</h5>
            <i class="bi bi-chevron-down ms-auto"></i>
        </div>
        <div class="collapse" id="csvSection">
            <div class="card-body">
                <p class="text-muted mb-3">
                    Format texte CSV — filtre par appartement. Conservé pour compatibilité.
                </p>

                {{ form_start(formExport, {
                    'action': path('admin_comptabilite_export_csv'),
                    'attr': {'class': ''}
                }) }}

                    <div class="d-flex flex-wrap gap-3 align-items-end">
                        <div style="min-width: 160px;">
                            {{ form_row(formExport.annee) }}
                        </div>
                        <div style="min-width: 260px;">
                            {{ form_row(formExport.appartement) }}
                        </div>
                        <div>
                            <button type="submit" class="btn btn-outline-secondary d-flex align-items-center gap-2">
                                <i class="bi bi-download"></i>
                                Télécharger le CSV
                            </button>
                        </div>
                    </div>

                {{ form_end(formExport) }}
            </div>
        </div>
    </div>

    {# ════════════════════════════════════════════════════════ #}
    {# 3. FRAIS ENREGISTRÉS                                    #}
    {# ════════════════════════════════════════════════════════ #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-dark text-white d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-cash-stack fs-5"></i>
                <h5 class="mb-0">Frais enregistrés ({{ annee }})</h5>
            </div>
            <a href="{{ path('admin_frais_new') }}" class="btn btn-sm btn-outline-light">
                <i class="bi bi-plus-lg"></i> Ajouter
            </a>
        </div>
        <div class="card-body p-0">
            {% if fraisList is not empty %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Type</th>
                                <th>Libellé</th>
                                <th>Appartement</th>
                                <th>Périodicité</th>
                                <th class="text-end">Montant</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for frais in fraisList %}
                                <tr>
                                    <td>
                                        <span class="badge bg-{{ _self.fraisBadgeColor(frais.typeFrais) }}">
                                            {{ frais.typeFraisLabel }}
                                        </span>
                                    </td>
                                    <td>{{ frais.libelle }}</td>
                                    <td>{{ frais.appartement ? frais.appartement.nom : 'Global' }}</td>
                                    <td>
                                        {{ constant('App\\Entity\\Frais::PERIODICITE_LABELS')[frais.periodicite] ?? frais.periodicite }}
                                        {% if frais.mois %}
                                            <small class="text-muted">({{ frais.mois }})</small>
                                        {% endif %}
                                    </td>
                                    <td class="text-end fw-semibold">{{ frais.montant|number_format(2, ',', ' ') }} €</td>
                                    <td class="text-center">
                                        <a href="{{ path('admin_frais_edit', {id: frais.id}) }}"
                                           class="btn btn-sm btn-outline-secondary" title="Modifier">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form action="{{ path('admin_frais_delete', {id: frais.id}) }}"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Supprimer ce frais ?')">
                                            <input type="hidden" name="_token"
                                                   value="{{ csrf_token('delete_frais_' ~ frais.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Aucun frais enregistré pour {{ annee }}.
                    <br>
                    <a href="{{ path('admin_frais_new') }}" class="btn btn-sm btn-gold mt-3">
                        <i class="bi bi-plus-lg"></i> Ajouter un premier frais
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    {# ════════════════════════════════════════════════════════ #}
    {# 4. AIDE                                                 #}
    {# ════════════════════════════════════════════════════════ #}
    <div class="card border-0 bg-light">
        <div class="card-body">
            <h6 class="card-title d-flex align-items-center gap-2">
                <i class="bi bi-info-circle text-primary"></i>
                Structure du fichier Excel généré
            </h6>
            <div class="row g-3 small text-muted">
                <div class="col-md-6">
                    <strong>Chaque onglet localisation contient :</strong>
                    <ul class="mb-0 mt-1">
                        <li>Réservations mois par mois (client, facture, durée, prix, total)</li>
                        <li>Sous-total mensuel avec taux d'occupation</li>
                        <li>Récapitulatif annuel taux d'occupation</li>
                        <li>Détail des frais de la localisation</li>
                        <li>Bilan financier (revenus — frais = résultat net)</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <strong>Onglet Récapitulatif :</strong>
                    <ul class="mb-0 mt-1">
                        <li>Tableau comparatif par localisation</li>
                        <li>Taux d'occupation, revenus, frais, résultat net</li>
                        <li>Bilan consolidé global</li>
                        <li>Résultats en vert (bénéfice) ou rouge (perte)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>

{% macro fraisBadgeColor(type) %}
    {%- if type == 'hebergement_site' -%}primary
    {%- elseif type == 'nettoyage' -%}info
    {%- elseif type == 'reparation' -%}warning
    {%- elseif type == 'assurance' -%}secondary
    {%- elseif type == 'taxe_sejour' -%}dark
    {%- else -%}light text-dark
    {%- endif -%}
{% endmacro %}
{% endblock %}
