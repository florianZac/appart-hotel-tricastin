{% extends 'base.html.twig' %}

{% block title %}Mes paiements — Appart Hôtel Tricastin{% endblock %}

{% block stylesheets %}
<style>
  .page-header { background: linear-gradient(135deg, #1a2744 0%, #2c3e5a 100%); padding: 60px 0 40px; margin-top: 80px; }
  .page-header h1 { font-family: 'Cormorant Garamond', serif; color: #c8a962; }
  .page-header .breadcrumb a { color: #c8a962; text-decoration: none; }
  .page-header .breadcrumb { color: #a0aec0; }
  .en-retard { background-color: #fff5f5 !important; }
</style>
{% endblock %}

{% block body %}
<section class="page-header">
  <div class="container">
    <nav class="breadcrumb mb-2"><a href="{{ path('client_dashboard') }}">Mon espace</a> / Paiements</nav>
    <h1>Mes paiements</h1>
  </div>
</section>

<section class="py-5">
  <div class="container">
    {% if payments|length > 0 %}
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Description</th>
            <th>Échéance</th>
            <th>Montant</th>
            <th>Statut</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for p in payments %}
          <tr class="{% if p.enRetard %}en-retard{% endif %}">
            <td>{{ p.createdAt|date('d/m/Y') }}</td>
            <td>{{ p.typeLabel }}</td>
            <td>{{ p.description|default('—') }}</td>
            <td>
              {% if p.dateEcheance %}
                {{ p.dateEcheance|date('d/m/Y') }}
                {% if p.enRetard %}<br><small class="text-danger fw-bold">En retard</small>{% endif %}
              {% else %}
                —
              {% endif %}
            </td>
            <td><strong>{{ p.montant }}€</strong></td>
            <td><span class="badge bg-{{ p.statutBadgeClass }}">{{ p.statutLabel }}</span></td>
            <td>
              {% if p.statut == 'en_attente' %}
                <form action="{{ path('payment_generic_checkout', {id: p.id}) }}" method="POST" class="d-inline">
                  <input type="hidden" name="_token" value="{{ csrf_token('payment_' ~ p.id) }}">
                  <button type="submit" class="btn btn-sm btn-reserve">
                    <i class="bi bi-credit-card"></i> Payer
                  </button>
                </form>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="text-center py-5">
      <i class="bi bi-credit-card" style="font-size: 3rem; color: #ccc;"></i>
      <p class="mt-3 text-muted">Aucun paiement enregistré.</p>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}
