{% extends 'base.html.twig' %}

{# ============================================================ #}
{# SEO — Andrieu ch.5 + ch.10 (ContactPage schema)             #}
{# route: app_contact                                           #}
{# ============================================================ #}
{% set seoOverride = {
    titre: 'Nous contacter — Appart Hôtel Tricastin',
    description: 'Une question sur votre séjour dans le Tricastin ? Contactez l\'équipe de l\'Appart Hôtel Tricastin. Réponse garantie sous 24h. Téléphone, email ou formulaire en ligne.',
    ogType: 'website'
} %}

{% block body %}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        {# Fil d'Ariane — Andrieu ch.6 #}
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-light">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}" title="Accueil Appart Hôtel Tricastin">{{ 'nav.home'|trans }}</a>
                </li>
                <li class="breadcrumb-item active">{{ 'contact.title'|trans }}</li>
            </ol>
        </nav>
        {# H1 ≠ title — Andrieu ch.5 #}
        <h1><i class="bi bi-chat-dots"></i> {{ 'contact.title'|trans }}</h1>
        <p class="lead">{{ 'contact.subtitle'|trans }}</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-7">
                <div class="form-card p-4 p-md-5 rounded-4">
                    <h2 class="mb-4"><i class="bi bi-envelope text-primary"></i> {{ 'contact.form_title'|trans }}</h2>

                    {{ form_start(form, {'attr': {'class': 'contact-form', 'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.telephone) }}
                            {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.telephone) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.sujet) }}
                        {{ form_widget(form.sujet, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.sujet) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.message) }}
                        {{ form_widget(form.message, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.message) }}
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-send"></i> {{ 'contact.send'|trans }}
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <div class="col-lg-5">
                <div class="contact-info-card p-4 rounded-4 mb-4">
                    <h3 class="mb-4">{{ 'contact.info_title'|trans }}</h3>

                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h6>{{ 'contact.address'|trans }}</h6>
                            <p>{{ site_address }}</p>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h6>{{ 'contact.telephone'|trans }}</h6>
                            <p><a href="tel:{{ site_phone|replace({' ': ''}) }}">{{ site_phone }}</a></p>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h6>{{ 'contact.email'|trans }}</h6>
                            <p><a href="mailto:{{ site_email }}">{{ site_email }}</a></p>
                        </div>
                    </div>
                </div>

                <div class="map-container rounded-4 overflow-hidden">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2760.5!2d0.33087!3d46.5812055!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47fdbf254c117ce5%3A0xb2bb43ed56f81d76!2sAppart%20H%C3%B4tel%20Tricastin!5e0!3m2!1sfr!2sfr!4v1700000000000"
                        width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy"
                        title="Localisation Appart Hôtel Tricastin"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
