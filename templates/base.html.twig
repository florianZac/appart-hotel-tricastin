<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Appart Hôtel Poitiers - Futuroscope{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Appart Hôtel Poitiers : 6 appartements meublés en plein cœur de Poitiers, à 10 min du Futuroscope. Réservez votre séjour idéal.{% endblock %}">

    {# Bootstrap 5 CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    {# Bootstrap Icons #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# ========================================= #}
    {# NAVBAR                                    #}
    {# ========================================= #}
    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <span class="brand-text">Appart Hôtel</span>
                <span class="brand-city">Poitiers</span>
            </a>

            <a href="{{ path('app_reservation') }}" class="btn btn-reserve d-lg-none ms-auto me-2">
                <i class="bi bi-star-fill"></i> Réserver
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_appartement' %}active{% endif %}" href="{{ path('app_appartements') }}">Les Appartements</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}" href="{{ path('app_contact') }}">Contact</a>
                    </li>
                    <li class="nav-item ms-lg-3 d-none d-lg-block">
                        <a href="{{ path('app_reservation') }}" class="btn btn-reserve">
                            <i class="bi bi-star-fill"></i> Réserver
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {# ========================================= #}
    {# FLASH MESSAGES                            #}
    {# ========================================= #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show flash-message" role="alert">
                <div class="container">
                    <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {# ========================================= #}
    {# MAIN CONTENT                              #}
    {# ========================================= #}
    <main id="main">
        {% block body %}{% endblock %}
    </main>

    {# ========================================= #}
    {# FOOTER                                    #}
    {# ========================================= #}
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                {# Colonne infos #}
                <div class="col-lg-4">
                    <h5 class="footer-brand">Appart Hôtel Poitiers</h5>
                    <address class="footer-address">
                        <p><i class="bi bi-geo-alt"></i> {{ site_address }}</p>
                        <p><i class="bi bi-telephone"></i> <a href="tel:{{ site_phone|replace({' ': ''}) }}">{{ site_phone }}</a></p>
                        <p><i class="bi bi-envelope"></i> <a href="mailto:{{ site_email }}">{{ site_email }}</a></p>
                    </address>
                </div>

                {# Colonne appartements #}
                <div class="col-lg-4">
                    <h5>Les Appartements</h5>
                    <ul class="footer-links">
                        <li><a href="{{ path('app_appartements') }}#imperial">★ L'Impérial</a></li>
                        <li><a href="{{ path('app_appartements') }}#suite">★ La Suite</a></li>
                        <li><a href="{{ path('app_appartements') }}#equinoxe">★ L'Équinoxe</a></li>
                        <li><a href="{{ path('app_appartements') }}#solstice">★ Le Solstice</a></li>
                        <li><a href="{{ path('app_appartements') }}#atlantide">★ L'Atlantide</a></li>
                        <li><a href="{{ path('app_appartements') }}#neptune">★ Le Neptune</a></li>
                    </ul>
                </div>

                {# Colonne réseaux sociaux #}
                <div class="col-lg-4">
                    <h5>Suivez-nous</h5>
                    <div class="social-links">
                        <a href="https://www.facebook.com/appart.hotel.poitiers1/" target="_blank" rel="noopener" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="https://www.instagram.com/appart_hotel_poitiers/" target="_blank" rel="noopener" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://g.page/r/CXYd-FbtQ7uyEAE/review" target="_blank" rel="noopener" aria-label="Google">
                            <i class="bi bi-google"></i>
                        </a>
                    </div>

                    <div class="footer-stats mt-4">
                        <div class="row text-center g-2">
                            <div class="col-6">
                                <div class="stat-number">2018</div>
                                <div class="stat-label">Depuis</div>
                            </div>
                            <div class="col-6">
                                <div class="stat-number">6</div>
                                <div class="stat-label">Appartements</div>
                            </div>
                            <div class="col-6">
                                <div class="stat-number">32</div>
                                <div class="stat-label">Capacité max</div>
                            </div>
                            <div class="col-6">
                                <div class="stat-number">1250+</div>
                                <div class="stat-label">Voyageurs</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">&copy; {{ "now"|date("Y") }} Appart Hôtel Poitiers. Tous droits réservés.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a href="#">Mentions légales</a>
                </div>
            </div>
        </div>
    </footer>

    {# ========================================= #}
    {# SCRIPTS                                   #}
    {# ========================================= #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
