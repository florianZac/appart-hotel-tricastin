{% extends 'base.html.twig' %}

{% block title %}
{{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }} — {{ 'site.title'|trans }}
{% endblock %}

{% block stylesheets %}
<style>
  .password-rules { list-style: none; padding: 0; margin: 10px 0; }
  .password-rules li { padding: 4px 0; font-size: .85rem; color: #999; transition: .2s; }
  .password-rules li.valid { color: #198754; }
  .password-rules li.valid::before { content: "✓ "; font-weight: 700; }
  .password-rules li.invalid { color: #dc3545; }
  .password-rules li.invalid::before { content: "✗ "; font-weight: 700; }
  .strength-bar {
    height: 8px;
    background: #e9ecef;
    border-radius: 50px;
    overflow: hidden;
    margin-top: 10px;
  }
  .strength-bar-inner {
    height: 100%;
    width: 0%;
    transition: width .3s ease, background .3s ease;
  }
  .password-match { font-size: .85rem; margin-top: 5px; }
  .password-wrapper { position: relative; }
  .password-wrapper input { padding-right: 40px; }
  .toggle-password {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; color: #6c757d; padding: 0; font-size: 1.1rem;
  }
</style>
{% endblock %}

{% block body %}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        <h1><i class="bi bi-lock"></i> {{ app.request.locale == 'fr' ? 'Connexion' : 'Login' }}</h1>
        <p class="lead">{{ app.request.locale == 'fr' ? 'réinitialiser votre mot de passe ' : 'reset your password' }}</p>
    </div>
</section>

<section class="py-5 ">
  <div class="container">
    <div class="row">
      <div class="col-lg-6">
        <div class="form-card p-4 p-md-5 rounded-4">

          <div class="text-center mb-4">
            <div class="login-icon-circle mx-auto mb-3">
                <i class="bi bi-person-lock"></i>
            </div>
              {{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }}
            </h2>
          </div>

          {# ================= FLASH ================= #}
          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                {{ message }}
              </div>
            {% endfor %}
          {% endfor %}

          {# ====== FORM : method="post" — soumission classique vers Symfony ====== #}
          <form method="post" id="resetPasswordForm">

            {# ================= MOT DE PASSE ================= #}
            <div class="mb-3">
              <label for="passwordInput" class="form-label">
                {{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }}
              </label>

              <div class="input-group">
                <input type="password"
                       id="passwordInput"
                       name="password"
                       class="form-control"
                       autocomplete="new-password"
                       required
                       placeholder="••••••••">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePw('passwordInput', this)">
                  <i class="bi bi-eye"></i>
                </button>
              </div>

              {# Barre de force #}
              <div class="strength-bar">
                <div id="strengthBar" class="strength-bar-inner"></div>
              </div>

              {# Règles temps réel #}
              <ul class="password-rules">
                <li id="r-length">8 caractères minimum</li>
                <li id="r-upper">1 lettre majuscule</li>
                <li id="r-lower">1 lettre minuscule</li>
                <li id="r-numbers">2 chiffres minimum</li>
                <li id="r-special">1 caractère spécial (!@#$%...)</li>
              </ul>
            </div>

            {# ================= CONFIRMATION ================= #}
            <div class="mb-4">
              <label for="confirmInput" class="form-label">
                {{ app.request.locale == 'fr' ? 'Confirmer le mot de passe' : 'Confirm password' }}
              </label>

              <div class="input-group">
                <input type="password"
                       id="confirmInput"
                       name="confirm_password"
                       class="form-control"
                       autocomplete="new-password"
                       required
                       placeholder="••••••••">
                <button type="button" class="btn btn-outline-secondary" onclick="togglePw('confirmInput', this)">
                  <i class="bi bi-eye"></i>
                </button>
              </div>

              <div id="matchText" class="password-match"></div>
            </div>

            {# ================= CSRF ================= #}
            <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}">

            {# ================= SUBMIT ================= #}
            <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100" disabled>
              <i class="bi bi-check-circle"></i>
              {{ app.request.locale == 'fr' ? 'Réinitialiser' : 'Reset password' }}
            </button>
          </form>

          <div class="text-center mt-4">
            <a href="{{ path('app_login') }}" class="text-muted small">
              <i class="bi bi-arrow-left"></i>
              {{ app.request.locale == 'fr' ? 'Retour à la connexion' : 'Back to login' }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {

  const password  = document.getElementById('passwordInput');
  const confirm   = document.getElementById('confirmInput');
  const submit    = document.getElementById('submitBtn');
  const bar       = document.getElementById('strengthBar');
  const matchText = document.getElementById('matchText');

  // =========================
  // RÈGLES PASSWORD
  // =========================
  const rules = {
    'r-length':  v => v.length >= 8,
    'r-upper':   v => /[A-Z]/.test(v),
    'r-lower':   v => /[a-z]/.test(v),
    'r-numbers': v => (v.match(/\d/g) || []).length >= 2,
    'r-special': v => /[\W_]/.test(v),
  };

  // =========================
  // FORCE DU MOT DE PASSE
  // =========================
  function calcStrength(v) {
    let score = 0;
    Object.values(rules).forEach(fn => { if (fn(v)) score++; });
    return score;
  }

  // =========================
  // VALIDATION GLOBALE
  // =========================
  function validate() {
    const val = password.value;
    let allValid = true;

    // Règles visuelles
    for (const [id, fn] of Object.entries(rules)) {
      const el = document.getElementById(id);
      if (!el) continue;
      const ok = fn(val);
      el.className = ok ? 'valid' : (val.length > 0 ? 'invalid' : '');
      if (!ok) allValid = false;
    }

    // Barre de force
    const strength = calcStrength(val);
    const pct = (strength / 5) * 100;
    bar.style.width = pct + '%';

    if (strength < 2)      bar.style.background = '#dc3545';
    else if (strength < 4) bar.style.background = '#ffc107';
    else                   bar.style.background = '#198754';

    // Correspondance
    let match = false;
    if (confirm.value.length > 0) {
      match = val === confirm.value;
      matchText.textContent = match ? '✓ Les mots de passe correspondent' : '✗ Les mots de passe ne correspondent pas';
      matchText.style.color = match ? '#198754' : '#dc3545';
    } else {
      matchText.textContent = '';
    }

    // Activation du bouton
    submit.disabled = !(allValid && match);
  }

  // =========================
  // EVENTS
  // =========================
  password.addEventListener('input', validate);
  confirm.addEventListener('input', validate);

  validate();
});

// =========================
// TOGGLE PASSWORD VISIBILITY
// =========================
function togglePw(inputId, btn) {
  const input = document.getElementById(inputId);
  const icon  = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.replace('bi-eye', 'bi-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.replace('bi-eye-slash', 'bi-eye');
  }
}
</script>
{% endblock %}