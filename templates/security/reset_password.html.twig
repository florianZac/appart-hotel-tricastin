{% extends 'base.html.twig' %}

{% block title %}{{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }} — {{ 'site.title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
  .password-rules { list-style: none; padding: 0; margin: 10px 0; }
  .password-rules li { padding: 4px 0; font-size: .85rem; color: #999; transition: color .3s; }
  .password-rules li.valid { color: #198754; }
  .password-rules li.valid::before { content: '✓ '; font-weight: 700; }
  .password-rules li.invalid::before { content: '✗ '; font-weight: 700; }
  .password-rules li.invalid { color: #dc3545; }
  .password-match { font-size: .85rem; margin-top: 4px; }
</style>
{% endblock %}

{% block body %}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        <h1><i class="bi bi-shield-lock"></i> {{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }}</h1>
    </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5">
        <div class="form-card p-4 p-md-5 rounded-4">

          <div class="text-center mb-4">
            <div class="login-icon-circle mx-auto mb-3">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h2 class="mb-1">{{ app.request.locale == 'fr' ? 'Définir un nouveau mot de passe' : 'Set a new password' }}</h2>
          </div>

          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                {{ message }}
              </div>
            {% endfor %}
          {% endfor %}

          <form method="post" id="resetPasswordForm">
            <div class="mb-3">
              <label for="passwordInput" class="form-label">
                <i class="bi bi-key"></i> {{ app.request.locale == 'fr' ? 'Nouveau mot de passe' : 'New password' }}
              </label>
              <div class="input-group input-group-lg">
                <input type="password"
                    name="password"
                    id="passwordInput"
                    class="form-control"
                    autocomplete="new-password"
                    required
                    placeholder="••••••••">
                <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('passwordInput', 'toggleIcon1')">
                  <i class="bi bi-eye" id="toggleIcon1"></i>
                </button>
              </div>

              {# Indicateurs de validité du mot de passe (Point 6) #}
              <ul class="password-rules" id="passwordRules">
                <li id="rule-length">8 caractères minimum</li>
                <li id="rule-uppercase">1 lettre majuscule</li>
                <li id="rule-lowercase">1 lettre minuscule</li>
                <li id="rule-numbers">2 chiffres minimum</li>
                <li id="rule-special">1 caractère spécial (!@#$%...)</li>
              </ul>
            </div>

            <div class="mb-4">
              <label for="confirmPasswordInput" class="form-label">
                <i class="bi bi-key-fill"></i> {{ app.request.locale == 'fr' ? 'Confirmer le mot de passe' : 'Confirm password' }}
              </label>
              <div class="input-group input-group-lg">
                <input type="password"
                    name="confirm_password"
                    id="confirmPasswordInput"
                    class="form-control"
                    autocomplete="new-password"
                    required
                    placeholder="••••••••">
                <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('confirmPasswordInput', 'toggleIcon2')">
                  <i class="bi bi-eye" id="toggleIcon2"></i>
                </button>
              </div>
              <div class="password-match" id="passwordMatch"></div>
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}">

            <button type="submit" class="btn btn-primary btn-lg w-100" id="submitBtn" disabled>
              <i class="bi bi-check-circle"></i>
              {{ app.request.locale == 'fr' ? 'Réinitialiser' : 'Reset password' }}
            </button>
          </form>

          <div class="text-center mt-4">
            <a href="{{ path('app_login') }}" class="text-muted small">
              <i class="bi bi-arrow-left"></i>
              {{ app.request.locale == 'fr' ? 'Retour à la connexion' : 'Back to login' }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const password = document.getElementById('passwordInput');
  const confirm  = document.getElementById('confirmPasswordInput');
  const submit   = document.getElementById('submitBtn');
  const matchDiv = document.getElementById('passwordMatch');

  const rules = {
    'rule-length':    (v) => v.length >= 8,
    'rule-uppercase': (v) => /[A-Z]/.test(v),
    'rule-lowercase': (v) => /[a-z]/.test(v),
    'rule-numbers':   (v) => (v.match(/\d/g) || []).length >= 2,
    'rule-special':   (v) => /[\W_]/.test(v),
  };

  function validate() {
    const val = password.value;
    let allValid = true;

    for (const [id, test] of Object.entries(rules)) {
      const el = document.getElementById(id);
      const ok = test(val);
      el.className = ok ? 'valid' : (val.length > 0 ? 'invalid' : '');
      if (!ok) allValid = false;
    }

    // Vérifier la correspondance
    let match = false;
    if (confirm.value.length > 0) {
      match = val === confirm.value;
      matchDiv.textContent = match ? '✓ Les mots de passe correspondent' : '✗ Les mots de passe ne correspondent pas';
      matchDiv.style.color = match ? '#198754' : '#dc3545';
    } else {
      matchDiv.textContent = '';
    }

    submit.disabled = !(allValid && match);
  }

  password.addEventListener('input', validate);
  confirm.addEventListener('input', validate);
});

function togglePasswordVisibility(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.replace('bi-eye', 'bi-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.replace('bi-eye-slash', 'bi-eye');
  }
}
</script>
{% endblock %}
