{% extends 'base.html.twig' %}

{% block title %}
{{ app.request.locale == 'fr' ? 'Mot de passe oublié' : 'Forgot password' }} — {{ 'site.title'|trans }}
{% endblock %}

{% block stylesheets %}
<style>
  .spinner {
    display: none;
    width: 18px;
    height: 18px;
    border: 2px solid #ccc;
    border-top: 2px solid #000;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .email-feedback {
    font-size: .85rem;
    margin-top: 5px;
  }
</style>
{% endblock %}

{% block body %}
<section class="register-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5">
        <div class="form-card p-4 p-md-5 rounded-4">

          <div class="text-center mb-4">
            <div class="login-icon-circle mx-auto mb-3">
                <i class="bi bi-envelope-paper"></i>
            </div>
            <h2 class="mb-1">{{ app.request.locale == 'fr' ? 'Réinitialisation' : 'Reset' }}</h2>
            <p class="text-muted small">
              {{ app.request.locale == 'fr'
                ? 'Saisissez votre adresse email. Si un compte existe, vous recevrez un lien de réinitialisation.'
                : 'Enter your email. If an account exists, you will receive a reset link.' }}
            </p>
          </div>

          {# ================= FLASH ================= #}
          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} d-flex align-items-center" role="alert">
                <i class="bi bi-{{ label == 'success' ? 'check-circle' : 'exclamation-triangle' }}-fill me-2"></i>
                {{ message }}
              </div>
            {% endfor %}
          {% endfor %}

          {# ====== FORM : method="post" + name sur les inputs = soumission Symfony ====== #}
          <form method="post" id="forgotForm">

            <div class="mb-3">
              <label for="emailInput" class="form-label">Email</label>

              <input type="email"
                     id="emailInput"
                     name="email"
                     class="form-control form-control-lg"
                     autocomplete="email"
                     required
                     autofocus
                     placeholder="votre@email.fr">

              {# Spinner + feedback AJAX #}
              <div class="d-flex align-items-center gap-2 mt-2">
                <div id="spinner" class="spinner"></div>
                <small id="emailStatus" class="email-feedback"></small>
              </div>
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">

            <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100">
              <i class="bi bi-send"></i>
              {{ app.request.locale == 'fr' ? 'Envoyer le lien' : 'Send reset link' }}
            </button>
          </form>

          <div class="text-center mt-4">
            <a href="{{ path('app_login') }}" class="text-muted small">
              <i class="bi bi-arrow-left"></i>
              {{ app.request.locale == 'fr' ? 'Retour à la connexion' : 'Back to login' }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {

  const email   = document.getElementById('emailInput');
  const spinner = document.getElementById('spinner');
  const status  = document.getElementById('emailStatus');

  let debounceTimer = null;

  // =========================
  // AJAX CHECK EMAIL (UX feedback uniquement — ne bloque pas le submit)
  // =========================
  function checkEmail() {
    clearTimeout(debounceTimer);

    debounceTimer = setTimeout(async () => {
      const val = email.value.trim();
      if (!val || !val.includes('@')) {
        status.textContent = '';
        return;
      }

      spinner.style.display = 'inline-block';
      status.textContent = '';

      try {
        const res = await fetch('/api/check-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: val })
        });
        const data = await res.json();

        if (data.exists && data.active) {
          status.textContent = 'Compte trouvé ✔ — lien envoyé possible';
          status.style.color = '#198754';
        } else if (data.exists && !data.active) {
          status.textContent = 'Compte désactivé — contactez l\'admin ⚠';
          status.style.color = '#e67e22';
        } else {
          status.textContent = 'Aucun compte associé ⚠';
          status.style.color = '#dc3545';
        }
      } catch (e) {
        status.textContent = 'Erreur serveur';
        status.style.color = '#dc3545';
      }

      spinner.style.display = 'none';
    }, 800);
  }

  email.addEventListener('input', checkEmail);
});
</script>
{% endblock %}
