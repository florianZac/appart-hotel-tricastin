{% extends 'base.html.twig' %}

{% block title %}{{ app.request.locale == 'fr' ? 'Mot de passe oublié' : 'Forgot password' }} — {{ 'site.title'|trans }}{% endblock %}

{% block body %}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        <h1><i class="bi bi-key"></i> {{ app.request.locale == 'fr' ? 'Mot de passe oublié' : 'Forgot password' }}</h1>
        <p class="lead">{{ app.request.locale == 'fr' ? 'Réinitialisez votre mot de passe par email' : 'Reset your password by email' }}</p>
    </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-5">
        <div class="form-card p-4 p-md-5 rounded-4">

          <div class="text-center mb-4">
            <div class="login-icon-circle mx-auto mb-3">
                <i class="bi bi-envelope-paper"></i>
            </div>
            <h2 class="mb-1">{{ app.request.locale == 'fr' ? 'Réinitialisation' : 'Reset' }}</h2>
            <p class="text-muted small">
              {{ app.request.locale == 'fr' 
                ? 'Saisissez votre adresse email. Si un compte existe, vous recevrez un lien de réinitialisation.' 
                : 'Enter your email. If an account exists, you will receive a reset link.' }}
            </p>
          </div>

          {% for label, messages in app.flashes %}
            {% for message in messages %}
              <div class="alert alert-{{ label }} d-flex align-items-center" role="alert">
                <i class="bi bi-{{ label == 'success' ? 'check-circle' : 'exclamation-triangle' }}-fill me-2"></i>
                {{ message }}
              </div>
            {% endfor %}
          {% endfor %}

          <form method="post">
            <div class="mb-4">
              <label for="emailInput" class="form-label">
                <i class="bi bi-envelope"></i> Email
              </label>
              <input type="email"
                  name="email"
                  id="emailInput"
                  class="form-control form-control-lg"
                  autocomplete="email"
                  required
                  autofocus
                  placeholder="votre@email.fr">
            </div>

            <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">

            <button type="submit" class="btn btn-primary btn-lg w-100">
              <i class="bi bi-send"></i>
              {{ app.request.locale == 'fr' ? 'Envoyer le lien' : 'Send reset link' }}
            </button>
          </form>

          <div class="text-center mt-4">
            <a href="{{ path('app_login') }}" class="text-muted small">
              <i class="bi bi-arrow-left"></i>
              {{ app.request.locale == 'fr' ? 'Retour à la connexion' : 'Back to login' }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
