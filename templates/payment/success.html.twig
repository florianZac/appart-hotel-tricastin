{% extends 'base.html.twig' %}

{% block title %}Paiement confirmé — Appart Hôtel Tricastin{% endblock %}

{% block body %}
<section style="margin-top: 120px;" class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 text-center">
        <div class="mb-4">
          <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h1 style="font-family: 'Cormorant Garamond', serif; color: #1a2744;">Paiement confirmé !</h1>
        <p class="lead text-muted">Votre paiement a été traité avec succès.</p>

        {% if payment %}
        <div class="card my-4 text-start">
          <div class="card-body">
            <p><strong>Type :</strong> {{ payment.typeLabel }}</p>
            <p><strong>Montant :</strong> {{ payment.montant }}€</p>
            {% if payment.reservation %}
            <p><strong>Réservation :</strong> {{ payment.reservation.appartement.nom }} — du {{ payment.reservation.dateArrivee|date('d/m/Y') }} au {{ payment.reservation.dateDepart|date('d/m/Y') }}</p>
            {% endif %}
            <p class="mb-0"><strong>Statut :</strong> <span class="badge bg-success">Payé</span></p>
          </div>
        </div>
        {% endif %}

        <p class="text-muted">Un email de confirmation vous a été envoyé.</p>

        <div class="d-flex justify-content-center gap-3 mt-4">
          <a href="{{ path('client_dashboard') }}" class="btn btn-reserve">
            <i class="bi bi-house"></i> Mon espace
          </a>
          <a href="{{ path('client_paiements') }}" class="btn btn-outline-dark">
            <i class="bi bi-credit-card"></i> Mes paiements
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
