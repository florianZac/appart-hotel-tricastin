{% extends 'base.html.twig' %}

{% block title %}Réserver - Appart Hôtel Tricastin{% endblock %}

{% block body %}
{# ================================================ #}
{# PAGE HEADER                                      #}
{# ================================================ #}
<section class="page-header">
    <div class="page-header-overlay"></div>
    <div class="container">
        <h1><i class="bi bi-star-fill"></i> Réserver votre séjour</h1>
        <p class="lead">Choisissez votre localisation, votre appartement et vos dates</p>
    </div>
</section>

{# ================================================ #}
{# FORMULAIRE DE RESERVATION                        #}
{# ================================================ #}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="form-card p-4 p-md-5 rounded-4">
                    <h2 class="mb-4 text-center">
                        <i class="bi bi-calendar-check text-primary"></i> Demande de réservation
                    </h2>

                    {{ form_start(form, {'attr': {'class': 'reservation-form', 'novalidate': 'novalidate'}}) }}

                    {# Étape 1 : Localisation #}
                    <div class="mb-3">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">1</span> Choisissez votre ville</h5>
                        {{ form_label(form.localisation) }}
                        {{ form_widget(form.localisation, {'attr': {'id': 'reservation_localisation'}}) }}
                        {{ form_errors(form.localisation) }}
                    </div>

                    {# Étape 2 : Appartement (filtré dynamiquement) #}
                    <div class="mb-4">
                        <h5 class="mb-3"><span class="badge bg-primary rounded-pill">2</span> Choisissez votre appartement</h5>
                        {{ form_label(form.appartement) }}
                        {{ form_widget(form.appartement, {'attr': {'id': 'reservation_appartement'}}) }}
                        {{ form_errors(form.appartement) }}
                        <div id="appartement-loading" class="text-muted small mt-1" style="display:none;">
                            <i class="bi bi-hourglass-split"></i> Chargement des appartements...
                        </div>
                    </div>

                    <hr class="my-4">

                    {# Étape 3 : Informations personnelles #}
                    <h5 class="mb-3"><span class="badge bg-primary rounded-pill">3</span> Vos informations</h5>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.telephone) }}
                            {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.telephone) }}
                        </div>
                    </div>

                    <hr class="my-4">

                    {# Étape 4 : Dates et personnes #}
                    <h5 class="mb-3"><span class="badge bg-primary rounded-pill">4</span> Votre séjour</h5>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            {{ form_label(form.dateArrivee) }}
                            {{ form_widget(form.dateArrivee, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.dateArrivee) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_label(form.dateDepart) }}
                            {{ form_widget(form.dateDepart, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.dateDepart) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_label(form.nombrePersonnes) }}
                            {{ form_widget(form.nombrePersonnes, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nombrePersonnes) }}
                        </div>
                    </div>

                    {# Message #}
                    <div class="mb-4">
                        {{ form_label(form.message) }}
                        {{ form_widget(form.message, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.message) }}
                    </div>

                    {# Submit #}
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            <i class="bi bi-send"></i> Envoyer ma demande
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        {# Infos complémentaires #}
        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="row g-4 text-center">
                    <div class="col-md-4">
                        <div class="info-mini-card">
                            <i class="bi bi-clock text-primary fs-2"></i>
                            <h6>Réponse rapide</h6>
                            <small class="text-muted">Nous répondons sous 24h</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-mini-card">
                            <i class="bi bi-shield-check text-primary fs-2"></i>
                            <h6>Paiement sécurisé</h6>
                            <small class="text-muted">Vos données sont protégées</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-mini-card">
                            <i class="bi bi-x-circle text-primary fs-2"></i>
                            <h6>Annulation flexible</h6>
                            <small class="text-muted">Conditions adaptées</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const localisationSelect = document.getElementById('reservation_localisation');
    const appartementSelect = document.getElementById('reservation_appartement');
    const loadingIndicator = document.getElementById('appartement-loading');

    if (!localisationSelect || !appartementSelect) return;

    localisationSelect.addEventListener('change', function () {
        const localisationId = this.value;

        // Vider le select appartement
        appartementSelect.innerHTML = '';

        if (!localisationId) {
            const option = document.createElement('option');
            option.value = '';
            option.textContent = '-- Sélectionnez d\'abord une ville --';
            appartementSelect.appendChild(option);
            return;
        }

        // Afficher le loading
        loadingIndicator.style.display = 'block';
        appartementSelect.disabled = true;

        // Appel AJAX
        fetch('/api/appartements-par-localisation/' + localisationId)
            .then(response => response.json())
            .then(data => {
                appartementSelect.innerHTML = '';

                // Placeholder
                const placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.textContent = '-- Choisissez un appartement --';
                appartementSelect.appendChild(placeholder);

                // Ajouter les appartements
                data.forEach(function (appart) {
                    const option = document.createElement('option');
                    option.value = appart.id;
                    option.textContent = appart.label;
                    appartementSelect.appendChild(option);
                });

                appartementSelect.disabled = false;
                loadingIndicator.style.display = 'none';
            })
            .catch(function (error) {
                console.error('Erreur chargement appartements:', error);
                appartementSelect.innerHTML = '<option value="">Erreur de chargement</option>';
                appartementSelect.disabled = false;
                loadingIndicator.style.display = 'none';
            });
    });
});
</script>
{% endblock %}