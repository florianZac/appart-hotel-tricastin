{% extends 'base.html.twig' %}

{% block title %}{{ 'apartments.page_title_city'|trans({'%ville%': localisation.ville}) }}{% endblock %}

{% block body %}
<section class="page-header">
  <div class="page-header-overlay"></div>
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb breadcrumb-light">
        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">{{ 'nav.home'|trans }}</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_appartements') }}">{{ 'apartments.page_title'|trans }}</a></li>
        <li class="breadcrumb-item active">{{ localisation.ville }}</li>
      </ol>
    </nav>
    <h1>{{ localisation.ville }}</h1>
    <p class="lead"><i class="bi bi-geo-alt"></i> {{ localisation.adresse }} — {{ localisation.codePostal }}</p>
  </div>
</section>

{% if localisation.description %}
<section class="py-4 bg-white">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <p class="lead">{{ localisation.description }}</p>
        {% if localisation.telephone or localisation.email %}
        <div class="mt-3">
          {% if localisation.telephone %}
            <span class="me-4"><i class="bi bi-telephone text-primary"></i> <a href="tel:{{ localisation.telephone|replace({' ': ''}) }}">{{ localisation.telephone }}</a></span>
          {% endif %}
          {% if localisation.email %}
            <span><i class="bi bi-envelope text-primary"></i> <a href="mailto:{{ localisation.email }}">{{ localisation.email }}</a></span>
          {% endif %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ================================================ #}
{# CARDS APPARTEMENTS CLIQUABLES                    #}
{# ================================================ #}
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-badge">{{ localisation.ville }}</span>
      <h2 class="section-title">{{ 'apartments.available_count'|trans({'%count%': appartements|length}) }}</h2>
    </div>

    <div class="row g-4">
      {% for appartement in appartements %}
      <div class="col-md-6 col-lg-4">
          <a href="{{ path('app_appartement_detail', {slug: appartement.slug}) }}" class="appart-card-link">
            <div class="appart-card">
              <div class="appart-card-img">
                <img src="/images/{{ appartement.imagePrincipale }}"
                  alt="{{ appartement.nom }}"
                  onerror="this.src='https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600&h=400&fit=crop'">
                <div class="appart-card-badge">{{ appartement.type }} — {{ appartement.surface }}{{ 'common.surface'|trans }}</div>
              </div>
              <div class="appart-card-body">
                <h3>{{ appartement.nom }}</h3>
                <div class="appart-card-meta">
                    <span><i class="bi bi-people"></i> {{ appartement.capaciteMin }}-{{ appartement.capaciteMax }} {{ 'common.people'|trans }}</span>
                    <span><i class="bi bi-tag"></i> {{ appartement.prixParNuit }}€{{ 'common.per_night'|trans }}</span>
                </div>
                <p class="mt-2 text-muted small">
                    {{ appartement.description|length > 100 ? appartement.description|slice(0, 100) ~ '...' : appartement.description }}
                </p>
                <div class="mt-2">
                  <span class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-eye"></i>
                      {{ app.request.locale == 'fr' ? 'Voir le détail & disponibilités' : 'View details & availability' }}
                  </span>
                </div>
              </div>
            </div>
          </a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-5">
      <a href="{{ path('app_appartements') }}" class="btn btn-outline-primary btn-lg">
        <i class="bi bi-arrow-left"></i> {{ 'apartments.back'|trans }}
      </a>
    </div>
  </div>
</section>

<section class="cta-section py-5">
  <div class="container text-center">
    <h2>{{ 'cta.apartment.title'|trans }}</h2>
    <p class="lead mb-4">{{ 'cta.apartment.subtitle'|trans({'%ville%': localisation.ville}) }}</p>
    <a href="{{ path('app_contact') }}" class="btn btn-outline-light btn-lg me-3">
      <i class="bi bi-chat-dots"></i> {{ 'footer.contact_us'|trans }}
    </a>
    <a href="{{ path('app_reservation') }}" class="btn btn-hero btn-lg">
      <i class="bi bi-star-fill"></i> {{ 'nav.book'|trans }}
    </a>
  </div>
</section>
{% endblock %}